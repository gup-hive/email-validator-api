# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Timeouts (seconds)
SMTP_TIMEOUT=10
MX_TIMEOUT=5

# Rate Limiting
RATE_LIMIT=100

# File Upload
MAX_FILE_SIZE=16777216

# Pricing (USD)
PRICING_PER_EMAIL=0.001
PRICING_MONTHLY_50K=29.0
