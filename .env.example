# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000

# API Keys Configuration
# Generate strong API keys for production use
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEMO_API_KEY=demo_key_123_change_in_production
PREMIUM_API_KEY=premium_key_456_change_in_production

# Security Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100
MAX_BATCH_SIZE=1000
MAX_CSV_SIZE=16777216  # 16MB

# Timeouts (seconds)
SMTP_TIMEOUT=10
MX_TIMEOUT=5

# Rate Limiting
RATE_LIMIT=100

# File Upload
MAX_FILE_SIZE=16777216

# Pricing (USD)
PRICING_PER_EMAIL=0.001
PRICING_MONTHLY_50K=29.0
